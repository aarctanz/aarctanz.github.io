---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const projects = [
    {
        name: "Exec0",
        desc: "Code execution API in Go with isolate sandbox",
        github: "https://github.com/aarctanz/Exec0",
    },
    {
        name: "CodeSpardha",
        desc: "Placement helper system API in TypeScript",
        github: "https://github.com/aarctanz/spring",
        live: "https://contest.codespardha.me",
    },
];
---

<Layout title="Arctan">
    <!-- Hero Section -->
    <section class="py-6">
        <img
            src="chigiri.jpeg"
            alt="arctan profile"
            class="w-24 h-24 rounded mb-4 object-cover grayscale hover:grayscale-0 transition-all duration-300"
        />

        <h1 class="text-[2.5rem] tracking-tight mb-4">ABHINAV KUMAR</h1>

        <p class="leading-relaxed opacity-90 mb-4 text-lg">
            An engineer who loves to tinker with distributed systems, databases,
            and core backend stuff.
        </p>

        <div
            class="flex items-center gap-2 mb-4 text-sm font-medium text-emerald-600 dark:text-emerald-400"
        >
            <span class="relative flex h-2 w-2">
                <span
                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
                ></span>
                <span
                    class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
                ></span>
            </span>
            Looking for work
        </div>

        <div class="flex gap-3 text-sm font-medium opacity-80">
            <a
                href="https://github.com/aarctanz"
                target="_blank"
                class="hover:underline hover:opacity-100 transition-opacity underline text-primary"
                >GitHub</a
            >
            <a
                href="https://twitter.com/aarctanz"
                target="_blank"
                class="hover:underline hover:opacity-100 transition-opacity underline text-primary"
                >Twitter</a
            >
        </div>
    </section>

    <!-- Blog Section -->
    <section id="blog" class="py-6 border-t border-border/30">
        <h2 class="text-2xl mb-4 pb-2 border-b border-dashed border-border/50">blogs</h2>
        <ul class="flex flex-col gap-2">
            {
                posts.map((post) => (
                    <li>
                        <a
                            href={`/blog/${post.slug}`}
                            class="group flex flex-col sm:flex-row sm:justify-between sm:items-baseline"
                        >
                            <span class="text-lg group-hover:underline opacity-90 group-hover:opacity-100 transition-opacity">
                                {post.data.title}
                            </span>
                            <span class="text-sm opacity-50 font-mono sm:ml-4">
                                {new Date(post.data.pubDate).toLocaleDateString(
                                    "en-US",
                                    {
                                        month: "short",
                                        day: "2-digit",
                                        year: "numeric",
                                    },
                                )}
                            </span>
                        </a>
                    </li>
                ))
            }
        </ul>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="py-6 border-t border-border/30">
        <h2 class="text-2xl mb-4 pb-2 border-b border-dashed border-border/50">projects</h2>
        <ul class="flex flex-col gap-2">
            {
                projects.map((p) => (
                    <li class="flex flex-col sm:flex-row sm:items-baseline gap-2">
                        <div class="flex-1">
                            <span class="font-medium text-lg opacity-90">
                                {p.name}
                            </span>
                            <span class="opacity-50 mx-1">:</span>
                            <span class="opacity-80 text-sm">{p.desc}</span>
                        </div>
                        <div class="flex gap-4 text-sm font-mono opacity-60 mt-1 sm:mt-0">
                            {p.live && (
                                <a
                                    href={p.live}
                                    target="_blank"
                                    class="hover:underline hover:opacity-100"
                                >
                                    live
                                </a>
                            )}
                            <a
                                href={p.github}
                                target="_blank"
                                class="hover:underline hover:opacity-100"
                            >
                                github
                            </a>
                        </div>
                    </li>
                ))
            }
        </ul>
    </section>

    <!-- CTA -->
    <section class="py-6 border-t border-border/30">
        <p class="text-lg opacity-80">
            Open for freelance projects and collaborations.
            <a href="mailto:arctan0@proton.me" class="underline hover:opacity-100">Get in touch</a>
        </p>
    </section>
</Layout>
